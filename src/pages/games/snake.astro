---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArcadeRanking from '../../components/ArcadeRanking.astro';
---

<BaseLayout title="// SNAKE — Arcade" description="Snake">
  <div class="game-wrapper">
    <div class="game-container">
      <div class="game-header">
        <a href="/games" class="back-link mono">← arcade</a>
        <span class="game-title mono accent">SNAKE</span>
        <div class="game-meta">
          <div class="meta-item"><span class="meta-label">SCORE</span><span class="meta-value" id="score">0</span></div>
          <div class="meta-item"><span class="meta-label">LEVEL</span><span class="meta-value" id="level">1</span></div>
        </div>
      </div>
      <div class="game-area">
        <canvas id="snake" width="400" height="400"></canvas>
      </div>
      <div class="mobile-controls">
        <div class="mobile-row"><button class="mobile-btn" id="btn-up">↑</button></div>
        <div class="mobile-row">
          <button class="mobile-btn" id="btn-left">←</button>
          <button class="mobile-btn" id="btn-down">↓</button>
          <button class="mobile-btn" id="btn-right">→</button>
        </div>
      </div>
      <div id="overlay" class="overlay">
        <div class="overlay-content">
          <div class="overlay-title">SNAKE</div>
          <div class="overlay-sub">Pulsa ENTER o toca para empezar</div>
        </div>
      </div>
    </div>
  </div>
  <ArcadeRanking gameId="snake" />
</BaseLayout>

<style>
.game-wrapper{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:6rem 1rem 2rem;}
.game-container{position:relative;display:flex;flex-direction:column;gap:1rem;max-width:440px;width:100%;}
.game-header{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.75rem;}
.back-link{font-family:var(--font-mono);font-size:.8rem;color:var(--text-muted);transition:color .2s;}
.back-link:hover{color:var(--accent);}
.game-title{font-size:1rem;letter-spacing:.1em;}
.game-meta{display:flex;gap:1.5rem;}
.meta-item{display:flex;flex-direction:column;align-items:center;}
.meta-label{font-family:var(--font-mono);font-size:.65rem;color:var(--text-muted);letter-spacing:.1em;}
.meta-value{font-family:var(--font-mono);font-size:1.1rem;font-weight:700;color:var(--accent);}
.game-area{display:flex;justify-content:center;}
#snake{border:1px solid var(--border-accent);border-radius:4px;background:var(--bg-secondary);box-shadow:0 0 30px rgba(0,212,170,.1);max-width:100%;height:auto;}
.mobile-controls{display:none;flex-direction:column;gap:.4rem;align-items:center;}
.mobile-row{display:flex;gap:.4rem;}
.mobile-btn{font-family:var(--font-mono);font-size:1rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;color:var(--accent);width:60px;height:60px;cursor:pointer;transition:all .15s;display:flex;align-items:center;justify-content:center;user-select:none;}
.mobile-btn:active{background:var(--accent-dim);border-color:var(--accent);}
@media(max-width:500px){.mobile-controls{display:flex;}#snake{width:320px;height:320px;}}
.overlay{position:absolute;inset:0;top:50px;display:flex;align-items:center;justify-content:center;background:rgba(8,13,19,.92);border-radius:4px;backdrop-filter:blur(4px);cursor:pointer;z-index:10;}
.overlay.hidden{display:none;}
.overlay-content{text-align:center;padding:2rem;}
.overlay-title{font-family:var(--font-mono);font-size:2.5rem;font-weight:700;color:var(--accent);letter-spacing:.2em;margin-bottom:.5rem;text-shadow:0 0 20px rgba(0,212,170,.5);}
.overlay-sub{font-size:.85rem;color:var(--text-secondary);font-family:var(--font-mono);}
.accent{color:var(--accent);}
.mono{font-family:var(--font-mono);}
</style>

<script>
const canvas = document.getElementById('snake') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
const overlay = document.getElementById('overlay')!;
const GRID = 20;
const COLS = canvas.width / GRID;
const ROWS = canvas.height / GRID;

let snake: {x:number,y:number}[], dir: {x:number,y:number}, nextDir: {x:number,y:number};
let food: {x:number,y:number};
let score: number, level: number;
let gameOver: boolean, started: boolean;
let animId: number, lastTime: number, interval: number;

function placeFood() {
  do { food = { x: Math.floor(Math.random()*COLS), y: Math.floor(Math.random()*ROWS) }; }
  while (snake.some(s => s.x===food.x && s.y===food.y));
}

function startGame() {
  snake = [{x:10,y:10},{x:9,y:10},{x:8,y:10}];
  dir = {x:1,y:0}; nextDir = {x:1,y:0};
  score = 0; level = 1; gameOver = false; started = true;
  interval = 150; lastTime = 0;
  placeFood();
  overlay.classList.add('hidden');
  cancelAnimationFrame(animId);
  animId = requestAnimationFrame(gameLoop);
  updateHUD();
}
(window as any).restartGame = startGame;

function updateHUD() {
  document.getElementById('score')!.textContent = score.toString();
  document.getElementById('level')!.textContent = level.toString();
}

function gameLoop(time: number) {
  if (gameOver) return;
  animId = requestAnimationFrame(gameLoop);
  if (time - lastTime < interval) return;
  lastTime = time;
  update();
  draw();
}

function update() {
  dir = nextDir;
  const head = { x: snake[0].x + dir.x, y: snake[0].y + dir.y };
  if (head.x < 0 || head.x >= COLS || head.y < 0 || head.y >= ROWS || snake.some(s=>s.x===head.x&&s.y===head.y)) {
    gameOver = true;
    cancelAnimationFrame(animId);
    (window as any).showRanking?.(score);
    return;
  }
  snake.unshift(head);
  if (head.x === food.x && head.y === food.y) {
    score += 10 * level;
    if (score % 100 === 0) { level++; interval = Math.max(60, interval - 15); }
    placeFood();
    updateHUD();
  } else { snake.pop(); }
}

function draw() {
  ctx.fillStyle = '#0d1520';
  ctx.fillRect(0, 0, canvas.width, canvas.height);
  // Grid
  ctx.strokeStyle = 'rgba(30,45,66,.4)';
  ctx.lineWidth = .5;
  for (let x=0;x<COLS;x++) for (let y=0;y<ROWS;y++) ctx.strokeRect(x*GRID,y*GRID,GRID,GRID);
  // Snake
  snake.forEach((seg, i) => {
    const alpha = i === 0 ? 1 : 0.6 + (0.4 * (snake.length - i) / snake.length);
    ctx.globalAlpha = alpha;
    ctx.fillStyle = i === 0 ? '#00d4aa' : '#00a884';
    ctx.fillRect(seg.x*GRID+1, seg.y*GRID+1, GRID-2, GRID-2);
    if (i === 0) {
      ctx.globalAlpha = 0.3;
      ctx.fillStyle = '#fff';
      ctx.fillRect(seg.x*GRID+2, seg.y*GRID+2, GRID-4, 3);
    }
  });
  ctx.globalAlpha = 1;
  // Food
  ctx.fillStyle = '#ef4444';
  ctx.beginPath();
  ctx.arc(food.x*GRID+GRID/2, food.y*GRID+GRID/2, GRID/2-2, 0, Math.PI*2);
  ctx.fill();
  ctx.fillStyle = '#ff6b6b';
  ctx.beginPath();
  ctx.arc(food.x*GRID+GRID/2-2, food.y*GRID+GRID/2-2, 3, 0, Math.PI*2);
  ctx.fill();
}

document.addEventListener('keydown', (e) => {
  if (!started || gameOver) { if (e.key==='Enter') startGame(); return; }
  if (e.key==='ArrowUp'    && dir.y===0) { e.preventDefault(); nextDir={x:0,y:-1}; }
  if (e.key==='ArrowDown'  && dir.y===0) { e.preventDefault(); nextDir={x:0,y:1}; }
  if (e.key==='ArrowLeft'  && dir.x===0) { e.preventDefault(); nextDir={x:-1,y:0}; }
  if (e.key==='ArrowRight' && dir.x===0) { e.preventDefault(); nextDir={x:1,y:0}; }
});

overlay.addEventListener('click', startGame);
document.getElementById('btn-up')?.addEventListener('click',    ()=>{ if(dir.y===0) nextDir={x:0,y:-1}; });
document.getElementById('btn-down')?.addEventListener('click',  ()=>{ if(dir.y===0) nextDir={x:0,y:1}; });
document.getElementById('btn-left')?.addEventListener('click',  ()=>{ if(dir.x===0) nextDir={x:-1,y:0}; });
document.getElementById('btn-right')?.addEventListener('click', ()=>{ if(dir.x===0) nextDir={x:1,y:0}; });
</script>
